# =============================================================================
# AIHub Platform — Environment Configuration
# Copy this to .env and fill in the values for your deployment.
# =============================================================================

# ---- Required in Production (debug=false) ----

# A strong random secret for signing JWT tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# ---- Encryption ----

# Master key for encrypting API keys and secrets at rest.
# If left empty, a key is automatically derived from the machine ID (stable per machine).
# Set this explicitly if deploying across multiple servers or containers.
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Changing this key means all existing encrypted secrets must be re-entered.
MASTER_ENCRYPTION_KEY=

# ---- Server ----

# Set to false for production (disables stack traces, enables JSON logging)
DEBUG=false

# ---- Database ----

# Default: SQLite in ./data/aihub.db
# DATABASE_URL=sqlite+aiosqlite:///./data/aihub.db

# ---- CORS ----

# Comma-separated list of allowed origins
# CORS_ORIGINS=["https://your-frontend-domain.com"]

# ---- Active Directory ----

# AD_MODE=ldap
# AD_HOST=ldap://your-dc.company.com
# AD_BASE_DN=DC=company,DC=com
# AD_BIND_DN=CN=svc-aihub,OU=ServiceAccounts,DC=company,DC=com
# AD_BIND_PASSWORD=
# AD_USER_SEARCH_BASE=OU=Users,DC=company,DC=com
# AD_ADMIN_GROUP=AIHub-Admins
# AD_DEVELOPER_GROUP=AIHub-Developers

# ---- App Runtime ----

# APP_BASE_PORT=9000
# APP_MAX_INSTANCES=50
