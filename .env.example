# AIHub Platform Configuration

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/aihub.db

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (for secrets management)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=change-me-generate-a-fernet-key

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# App Runtime
APP_DATA_DIR=./data/apps
APP_BASE_PORT=9000
APP_MAX_INSTANCES=50

# Active Directory (Mock mode for development)
AD_MODE=mock
AD_HOST=ldaps://your-dc.example.com
AD_BASE_DN=DC=example,DC=com
AD_BIND_DN=CN=svc-aihub,OU=ServiceAccounts,DC=example,DC=com
AD_BIND_PASSWORD=
AD_USER_SEARCH_BASE=OU=Users,DC=example,DC=com
AD_ADMIN_GROUP=CN=AIHub-Admins,OU=Groups,DC=example,DC=com
AD_DEVELOPER_GROUP=CN=AIHub-Developers,OU=Groups,DC=example,DC=com

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
