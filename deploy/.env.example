# AIHub platform — environment for the Docker Compose distribution.
# Copy to .env and fill in. NEVER commit the real .env.

# REQUIRED — a strong random secret for signing JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# Optional — the Fernet master key for encrypting stored secrets. If empty,
# AIHub derives a stable key from the machine id. For portable backups across
# machines, set this to a fixed value:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=

# Optional — paste a license JWT here, or mount data/license.key into the volume.
AIHUB_LICENSE=

# Auth: "mock" (dev creds admin/password) or "ldap" (configure in the admin UI).
AD_MODE=mock

# --- Transport security -----------------------------------------------------
# AIHub serves cookies/JWTs/logins and MUST run behind TLS in production. Put a
# reverse proxy (nginx/Caddy/IIS-ARR) in front terminating HTTPS and forwarding
# to this container; the image runs uvicorn with --proxy-headers so the request
# scheme is detected from X-Forwarded-Proto.
#
# Secure flag on the refresh cookie:
#   empty/unset → auto (Secure when the request is HTTPS — correct behind a proxy
#                 that sets X-Forwarded-Proto). Recommended.
#   true        → force Secure (set this if you terminate TLS but can't forward
#                 the proto header).
#   false       → never Secure (HTTP-only lab; accept the risk).
COOKIE_SECURE=
# Emit HSTS on HTTPS responses (no effect on plain HTTP). Leave enabled.
HSTS_ENABLED=true

# Set true only for local development.
DEBUG=false
