# When building this app for deployment off the AIHub host, the platform's
# builder sets VITE_AIHUB_BASE_URL to the public AIHub URL (e.g.
# https://aihub.example.com). The SDK uses it for runtime config + auth calls.
#
# Leave unset for local preview — the SDK falls back to same-origin / injected
# globals from the AIHub preview proxy.
VITE_AIHUB_BASE_URL=
